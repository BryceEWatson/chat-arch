---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ChatArchViewer } from '@chat-arch/viewer';
import '@chat-arch/viewer/style.css';
---
<BaseLayout title="Chat Archaeologist">
  <main>
    <ChatArchViewer client:load />
    {/*
      Hint paragraph removed — it lived below the viewer and pushed the
      document 50+px past the viewport, creating a vestigial scrollbar
      on the empty state. The viewer's own ErrorState copy already
      covers the same "run the exporter / upload / load demo" guidance,
      so the trailing hint was duplicative anyway.
    */}
  </main>
</BaseLayout>
