---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ChatArchViewer } from '@chat-arch/viewer';
import '@chat-arch/viewer/style.css';
---
<BaseLayout title="Chat Archaeologist">
  <main>
    <ChatArchViewer client:load />
    <p style="margin-top: 2rem; font-size: 0.875rem; opacity: 0.7;">
      To load real data, run <code>pnpm --filter @chat-arch/exporter start</code>.
    </p>
  </main>
</BaseLayout>
