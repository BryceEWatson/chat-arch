# Strict peer dep resolution — catches missing peers early.
strict-peer-dependencies=true
# Keep a single lockfile at the workspace root (default, but explicit).
shared-workspace-lockfile=true
# Avoid hoisting surprise deps into package-internal node_modules.
# "isolated" node_modules is pnpm's default, spelled out for clarity.
node-linker=isolated
# Auto-install peers where possible (React across viewer + standalone).
auto-install-peers=true
